# ─── Database ──────────────────────────────────────────────
POSTGRES_DB=ngx_saas
POSTGRES_USER=ngx
POSTGRES_PASSWORD=ngx_password
# asyncpg driver for the app, sync (psycopg) is derived for Alembic
DATABASE_URL=postgresql+asyncpg://ngx:ngx_password@db:5432/ngx_saas

# ─── Redis (cache, Celery broker, pub/sub) ─────────────────
REDIS_URL=redis://redis:6379/0

# ─── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_run_python_secrets_token_urlsafe_48
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Market data ───────────────────────────────────────────
NGXPULSE_API_KEY=
NGXPULSE_BASE_URL=https://www.ngxpulse.ng/api/ngxdata

# ─── App ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost:5173
ENVIRONMENT=development

# ─── Frontend (Vite, exposed at build/runtime) ─────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/api/v1/ws/prices
